/*
 * Chapter 04: Data Formats
 * 목적: 숫자, 문자, 날짜 데이터의 출력 형식을 지정하는 방법 학습
 * 출처: https://wikidocs.net/book/2678
 */
LIBNAME SASTEST "/home/u63652680/my_sas_data";

/* 4-1 숫자 포맷 */
DATA TEST;
INPUT NAME :$20. AGE;
CARDS;
라이올라 3245.678
;
RUN;

PROC PRINT DATA = TEST;
VAR AGE;
FORMAT AGE 5.;
RUN;

PROC PRINT DATA = TEST;
VAR AGE;
FORMAT AGE 6.2;
RUN;

PROC PRINT DATA = TEST;
VAR AGE;
FORMAT AGE BEST5.;
RUN;

PROC PRINT DATA = TEST;
VAR AGE;
FORMAT AGE COMMA5.;
RUN;

DATA TEST;
LENGTH NAME $20;
INPUT NAME $ AGE;
CARDS;
라이올라 0.3245678
;
RUN;

PROC PRINT DATA = TEST;
VAR AGE;
FORMAT AGE PERCENT8.2; /* % 는 세 자리를 차지 */
RUN;

PROC PRINT DATA = TEST;
VAR AGE;
FORMAT AGE Z7.2;
RUN;

/* 4-2 문자 포맷 */
DATA TEST;
LENGTH NAME $20.;
INPUT NAME $ AGE;
CARDS;
라이올라 324.5678
;
RUN;

PROC PRINT DATA = TEST;
VAR NAME;
FORMAT NAME $6.;
RUN;

/* 4-3 날짜 포맷 */
DATA TEST;
INPUT NAME $ NUMBER;
CARDS;
날짜 3
;
RUN;

PROC PRINT DATA = TEST;
VAR NUMBER;
FORMAT NUMBER DATE10.;
RUN;

PROC PRINT DATA = TEST;
VAR NUMBER;
FORMAT NUMBER YYMMDD10.;
RUN;

PROC PRINT DATA = TEST;
VAR NUMBER;
FORMAT NUMBER WEEKDATE.;
RUN;

PROC PRINT DATA = TEST;
VAR NUMBER;
FORMAT NUMBER WORDDATE.;
RUN;

PROC PRINT DATA = TEST;
VAR NUMBER;
FORMAT NUMBER YYMMN6.;
RUN;

PROC PRINT DATA = TEST;
VAR NUMBER;
FORMAT NUMBER MONYY7.;
RUN;

PROC PRINT DATA = TEST;
VAR NUMBER;
FORMAT NUMBER YEAR4.;
RUN;

PROC PRINT DATA = TEST;
VAR NUMBER;
FORMAT NUMBER DATETIME20.;
RUN;

PROC PRINT DATA = TEST;
VAR NUMBER;
FORMAT NUMBER TIME8.;
RUN;

PROC PRINT DATA = TEST;
VAR NUMBER;
FORMAT NUMBER HHMM5.;
RUN;

PROC PRINT DATA = TEST;
VAR NUMBER;
FORMAT NUMBER HOUR5.;
RUN;